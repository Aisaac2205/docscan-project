{
  "name": "scanner-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Local Windows scanner agent for DocScan OCR",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js scan",
    "dev": "ts-node src/index.ts scan",
    "flush-queue": "node dist/index.js flush-queue",
    "dev:flush-queue": "ts-node src/index.ts flush-queue",
    "daemon": "node dist/index.js daemon",
    "dev:daemon": "ts-node src/index.ts daemon"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
